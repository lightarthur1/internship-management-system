# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb://localhost:27017/ims-portal
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/ims-portal

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Admin Credentials (hardcoded — only these unlock the admin dashboard)
ADMIN_EMAIL=admin@ims-portal.com
ADMIN_PASSWORD=IMS@Admin2024!
ADMIN_USERNAME=imsadmin

# Email (for workplace supervisor invite emails)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=IMS Portal <noreply@ims-portal.com>

# Frontend URL (for CORS and email links)
CLIENT_URL=http://localhost:5173
